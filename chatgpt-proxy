<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Chat Acesso</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #1a1a1a;
            color: #fff;
            height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .header {
            background: #2d2d2d;
            padding: 12px 16px;
            border-bottom: 1px solid #404040;
            display: flex;
            align-items: center;
            gap: 10px;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .dot { 
            width: 10px; 
            height: 10px; 
            background: #10a37f; 
            border-radius: 50%;
            animation: pulse 2s infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        .proxy-selector {
            background: #2d2d2d;
            padding: 10px;
            border-bottom: 1px solid #404040;
            display: flex;
            gap: 8px;
            overflow-x: auto;
        }
        .proxy-btn {
            background: #404040;
            border: none;
            color: #fff;
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 12px;
            white-space: nowrap;
            cursor: pointer;
        }
        .proxy-btn.active {
            background: #10a37f;
        }
        .container {
            flex: 1;
            position: relative;
            overflow: hidden;
        }
        iframe {
            width: 100%;
            height: 100%;
            border: none;
            background: #fff;
        }
        .fallback {
            padding: 20px;
            text-align: center;
            display: none;
        }
        .fallback a {
            color: #10a37f;
            text-decoration: none;
            display: block;
            margin: 10px 0;
            padding: 15px;
            background: #2d2d2d;
            border-radius: 8px;
        }
        .loading {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #888;
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="dot"></div>
        <span style="font-size: 16px; font-weight: 500;">Acesso Direto</span>
        <span style="margin-left: auto; font-size: 12px; color: #888;">v2.0</span>
    </div>

    <div class="proxy-selector">
        <button class="proxy-btn active" onclick="setProxy('cors')">Método 1 (CORS)</button>
        <button class="proxy-btn" onclick="setProxy('translate')">Método 2 (Translate)</button>
        <button class="proxy-btn" onclick="setProxy('cached')">Método 3 (Cached)</button>
        <button class="proxy-btn" onclick="showFallback()">Links Diretos</button>
    </div>

    <div class="container" id="container">
        <div class="loading" id="loading">Carregando...</div>
        <iframe id="frame" sandbox="allow-scripts allow-same-origin allow-forms allow-popups"></iframe>
    </div>

    <div class="fallback" id="fallback">
        <h3>🚀 Links de Acesso Alternativos</h3>
        <p style="color: #888; margin: 10px 0; font-size: 14px;">
            Se nenhum método funcionar, tente estes links diretamente:
        </p>
        <a href="https://chatgpt.com" target="_blank">🔗 ChatGPT Oficial (direto)</a>
        <a href="https://r.jina.ai/http://chat.openai.com" target="_blank">🔗 Via Jina AI (leve)</a>
        <a href="https://r.jina.ai/http://chatgpt.com" target="_blank">🔗 Via Jina AI v2</a>
        <a href="https://r.jina.ai/http://chat.openai.com/chat" target="_blank">🔗 Chat Direto (texto)</a>
        <a href="https://cc.bingj.com/cache.aspx?d=503-... (use Bing Cached)" onclick="alert('Cole o URL do ChatGPT no Bing Cached')" target="_blank">🔗 Bing Cached (manual)</a>
        
        <div style="margin-top: 20px; padding: 15px; background: #252525; border-radius: 8px; text-align: left;">
            <strong style="color: #10a37f;">💡 Dica:</strong>
            <p style="color: #aaa; font-size: 13px; margin-top: 8px; line-height: 1.5;">
                Se o seu WiFi bloqueia, tente usar dados móveis temporariamente, 
                ou use o "Modo Avião" por 10 segundos para renovar o IP.
            </p>
        </div>
    </div>

    <script>
        const proxies = {
            cors: [
                'https://api.allorigins.win/raw?url=https://chat.openai.com',
                'https://api.codetabs.com/v1/proxy?quest=https://chat.openai.com',
                'https://thingproxy.freeboard.io/fetch/https://chat.openai.com'
            ],
            translate: [
                'https://r.jina.ai/http://chat.openai.com',
                'https://r.jina.ai/http://chatgpt.com',
                'https://r.jina.ai/http://chat.openai.com/chat'
            ],
            cached: [
                'https://webcache.googleusercontent.com/search?q=chat.openai.com',
                'https://r.jina.ai/http://textise.net/showtext.aspx?strUrl=https://chat.openai.com'
            ]
        };

        let currentMethod = 'cors';

        function setProxy(method) {
            currentMethod = method;
            document.querySelectorAll('.proxy-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            
            document.getElementById('fallback').style.display = 'none';
            document.getElementById('container').style.display = 'block';
            document.getElementById('loading').style.display = 'block';
            
            // Tenta múltiplos proxies do método selecionado
            tryLoad(proxies[method], 0);
        }

        function tryLoad(urls, index) {
            if (index >= urls.length) {
                document.getElementById('loading').innerHTML = '⚠️ Todos os métodos falharam. Tente "Links Diretos" acima.';
                return;
            }
            
            const frame = document.getElementById('frame');
            frame.src = urls[index];
            
            frame.onload = () => {
                document.getElementById('loading').style.display = 'none';
            };
            
            frame.onerror = () => {
                setTimeout(() => tryLoad(urls, index + 1), 2000);
            };
            
            // Timeout de segurança
            setTimeout(() => {
                if (document.getElementById('loading').style.display !== 'none') {
                    tryLoad(urls, index + 1);
                }
            }, 8000);
        }

        function showFallback() {
            document.querySelectorAll('.proxy-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            document.getElementById('container').style.display = 'none';
            document.getElementById('fallback').style.display = 'block';
        }

        // Inicia automaticamente
        window.onload = () => {
            tryLoad(proxies.cors, 0);
        };

        // Previne erros de navegação
        window.onerror = () => {
            document.getElementById('loading').innerHTML = 'Tentando método alternativo...';
        };
    </script>
</body>
</html>
